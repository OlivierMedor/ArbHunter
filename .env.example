# ArbHunter Environment Variables

# RPC Endpoints
QUICKNODE_HTTP_URL=
QUICKNODE_WSS_URL=
ALCHEMY_HTTP_URL=
ALCHEMY_WSS_URL=
TENDERLY_RPC_URL=

# Database
DB_USER=arb
DB_PASS=arb
DB_NAME=arb_metrics
DB_HOST=localhost
DB_PORT=5432

# Logging & Metrics
RUST_LOG=info
METRICS_PORT=9090

# Phase 9: Wallet & Submission
SIGNER_PRIVATE_KEY=
EXECUTOR_CONTRACT_ADDRESS=
ENABLE_BROADCAST=false
DRY_RUN_ONLY=true

# Phase 10: Preflight & Safe Broadcast
RPC_HTTP_URL=
REQUIRE_PREFLIGHT=true
REQUIRE_GAS_ESTIMATE=true
REQUIRE_ETH_CALL=true

# Phase 12: Forked E2E Harness
ANVIL_FORK_URL=
ANVIL_FORK_BLOCK_NUMBER=
ANVIL_RPC_URL=http://127.0.0.1:8545
TEST_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Phase 15: Live Shadow Mode
ENABLE_SHADOW_MODE=false
SHADOW_RECHECK_DELAY_MS=5000
SHADOW_MIN_PROFIT_THRESHOLD=0
SHADOW_MAX_CANDIDATES_PER_WINDOW=100
SHADOW_WRITE_JOURNAL=true
SHADOW_JOURNAL_PATH=shadow_journal.jsonl

# Phase 16: Historical Shadow Calibration (1-Hour Slice Path B)
ENABLE_HISTORICAL_SHADOW_REPLAY=false
HISTORICAL_REPLAY_LOOKBACK_HOURS=24
HISTORICAL_REPLAY_START_BLOCK=43638000
HISTORICAL_REPLAY_END_BLOCK=43639800
HISTORICAL_RECHECK_BLOCKS=1
HISTORICAL_REPLAY_OUTPUT_PATH=historical_replay_calibration_final.json
HISTORICAL_REPLAY_METRICS_PORT=9091
HISTORICAL_MAX_CASES_TO_VERIFY=5

# MIN_GROSS_PROFIT (Shared with Phase 7/15)
MIN_GROSS_PROFIT=10000000000000000

# Phase 24: Controlled Live-Canary Hardening
CANARY_LIVE_MODE_ENABLED=false
CANARY_STATE_PATH=canary_state.json
CANARY_PERSIST_SIGNED_RAW=false
CANARY_MAX_TRADE_SIZE_WEI=30000000000000000
CANARY_MAX_CONCURRENT_TRADES=1
CANARY_MAX_CONSECUTIVE_REVERTS=3
CANARY_LOSS_CAP_WEI=50000000000000000
CANARY_REVIEW_THRESHOLD_ATTEMPTS=30

# Preflight & Tenderly (Global/Phase 24 Hardening)
TENDERLY_ENABLED=false
TENDERLY_API_KEY=
TENDERLY_ACCOUNT_SLUG=
TENDERLY_PROJECT_SLUG=
TENDERLY_TIMEOUT_MS=10000
GAS_LIMIT_MULTIPLIER_BPS=12000
GAS_LIMIT_MIN=21000
GAS_LIMIT_MAX=5000000
